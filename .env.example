# Groq LLM — get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Kafka — populate from: terraform output / Instaclustr console Connection Info
KAFKA_BOOTSTRAP_SERVERS=broker1:9092,broker2:9092,broker3:9092
KAFKA_TOPIC=server-stats
KAFKA_CONSUMER_GROUP=infra-monitor-consumer
KAFKA_SASL_USERNAME=your_kafka_username
KAFKA_SASL_PASSWORD=your_kafka_password
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_SASL_MECHANISM=SCRAM-SHA-256

# Cassandra — populate from: terraform output / Instaclustr console Connection Info
CASSANDRA_CONTACT_POINTS=host1,host2,host3
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=infra_monitor
CASSANDRA_USERNAME=your_cassandra_username
CASSANDRA_PASSWORD=your_cassandra_password

# App config
SERVER_POLL_INTERVAL_SECONDS=300
DASHBOARD_PORT=8000
