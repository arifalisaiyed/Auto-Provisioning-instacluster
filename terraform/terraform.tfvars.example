# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored — never commit credentials.
# Get your API key from: https://console2.instaclustr.com/account/api-keys

instaclustr_username = "your-email@example.com"
instaclustr_api_key  = "your-provisioning-api-key"

cloud_provider = "AWS_VPC"
region         = "US_EAST_1"
network_cidr   = "10.0.0.0/16"
project_name   = "infra-monitor"
